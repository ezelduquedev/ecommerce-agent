# ==============================================
# VARIABLES DE ENTORNO — PLANTILLA PÚBLICA
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env real al repositorio
# ==============================================

# --- Groq API ---
# Obtén tu clave gratuita en: https://console.groq.com
GROQ_API_KEY=gsk_TU_CLAVE_AQUI

# --- Modelo LLM ---
MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024
TEMPERATURE=0.3

# --- Base de datos (lowdb / JSON) ---
DB_PATH=./db/orders.json

# --- Entorno ---
NODE_ENV=development
